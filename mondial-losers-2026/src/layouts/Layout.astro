---
interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = 'A satirical scoreboard of every team knocked out of the 2026 FIFA World Cup — with a roast for the road.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">
				<span class="brand-card" aria-hidden="true"></span>
				Mondial Losers <span class="year">2026</span>
			</a>
			<p class="tagline">Every team the 2026 World Cup has shown the door — with a roast on the way out.</p>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>
				Elimination results sourced from public World Cup coverage. Roasts are satire, served with love —
				every team here won the right to lose on the world's biggest stage.
			</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--pitch: #0b3d24;
		--pitch-dark: #062615;
		--pitch-line: rgba(255, 255, 255, 0.14);
		--red: #dc2626;
		--red-dark: #991b1b;
		--gold: #fbbf24;
		--paper: #f7f5ef;
		--ink: #10251a;
		font-family:
			'Inter',
			system-ui,
			-apple-system,
			Segoe UI,
			Roboto,
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at 50% -10%, var(--pitch-line), transparent 45%),
			repeating-linear-gradient(
				0deg,
				var(--pitch) 0px,
				var(--pitch) 64px,
				var(--pitch-dark) 64px,
				var(--pitch-dark) 128px
			);
		color: var(--paper);
	}

	.site-header {
		max-width: 960px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 1.5rem;
		text-align: center;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-size: clamp(1.8rem, 5vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--paper);
		text-decoration: none;
	}

	.brand-card {
		display: inline-block;
		width: 0.7em;
		height: 1em;
		background: linear-gradient(160deg, var(--red), var(--red-dark));
		border-radius: 0.12em;
		box-shadow: 0 0.08em 0 rgba(0, 0, 0, 0.35);
		transform: rotate(-8deg);
	}

	.brand .year {
		color: var(--gold);
	}

	.tagline {
		margin: 0.75rem auto 0;
		max-width: 40ch;
		color: rgba(247, 245, 239, 0.75);
		font-size: 1rem;
	}

	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 3rem;
	}

	.site-footer {
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
		text-align: center;
		color: rgba(247, 245, 239, 0.55);
		font-size: 0.85rem;
	}

	a {
		color: inherit;
	}
</style>
